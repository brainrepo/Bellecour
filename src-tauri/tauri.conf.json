{
  "$schema": "https://raw.githubusercontent.com/nicedl/tauri-settings/main/schema.json",
  "productName": "Belcour",
  "version": "0.1.0",
  "identifier": "com.belcour.voice",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "overlay",
        "title": "Belcour",
        "url": "/",
        "width": 300,
        "height": 80,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "x": 600,
        "y": 40
      },
      {
        "label": "settings",
        "title": "Belcour Settings",
        "url": "/settings.html",
        "width": 480,
        "height": 560,
        "visible": false,
        "decorations": true,
        "center": true,
        "resizable": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    }
  }
}
